{
  "name": "app-ai-content-operator",
  "version": "2.1.0",
  "private": true,
  "description": "Juke AI Content Operator",
  "homepage": "https://github.com/enonic/app-ai-content-operator",
  "bugs": {
    "url": "https://github.com/enonic/app-ai-content-operator/issues"
  },
  "license": "Enonic License 2.0",
  "author": "Enonic",
  "contributors": [
    "Mikita Taukachou <edloidas@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/app-ai-content-operator"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "pnpm run /^build:prod:.*/",
    "build:prod:client": "NODE_ENV=production vp build --mode production",
    "build:prod:server": "NODE_ENV=production node esbuild.server.js",
    "build:dev": "pnpm run /^build:dev:.*/",
    "build:dev:client": "NODE_ENV=development vp build --mode development",
    "build:dev:server": "NODE_ENV=development node esbuild.server.js",
    "check": "vp lint && pnpm check:types && pnpm test",
    "check:types": "tsgo --noEmit -p src/main/resources/tsconfig.json && tsgo --noEmit",
    "test": "vp test --run",
    "fix": "vp fmt && vp lint --fix",
    "prepare": "vp config",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@nanostores/react": "~1.1.0",
    "i18next": "~26.2.0",
    "i18next-http-backend": "~4.0.0",
    "lodash.clonedeep": "~4.5.0",
    "lodash.isequal": "~4.5.0",
    "lodash.merge": "~4.6.2",
    "lucide-react": "~1.16.0",
    "nanoid": "~5.1.11",
    "nanostores": "~1.3.0",
    "preact": "~10.29.2",
    "react-i18next": "~17.0.8",
    "slate": "~0.126.0",
    "slate-history": "~0.113.1",
    "slate-react": "~0.124.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@enonic-types/core": "^8",
    "@enonic-types/global": "^8",
    "@enonic-types/lib-auth": "^8",
    "@enonic-types/lib-task": "^8",
    "@enonic-types/lib-websocket": "^8",
    "@enonic/ui": "^1.0.4",
    "@google/genai": "~2.4.0",
    "@preact/preset-vite": "~2.10.5",
    "@storybook/addon-docs": "~10.4.4",
    "@storybook/addon-themes": "~10.4.2",
    "@storybook/preact-vite": "~10.4.4",
    "@swc/core": "^1.15.33",
    "@tailwindcss/typography": "~0.5.19",
    "@tailwindcss/vite": "~4.3.0",
    "@testing-library/jest-dom": "~6.9.1",
    "@types/lodash.clonedeep": "~4.5.9",
    "@types/lodash.isequal": "~4.5.8",
    "@types/lodash.merge": "~4.6.9",
    "@types/node": "~25.9.3",
    "@types/react": "~19.2.16",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "esbuild": "~0.28.1",
    "jsdom": "~29.1.1",
    "storybook": "~10.4.2",
    "tailwindcss": "~4.3.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.1.1"
  },
  "packageManager": "pnpm@11.1.1"
}
